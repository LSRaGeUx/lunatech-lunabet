# PostgreSQL (le docker-compose mappe sur 5434 pour éviter les conflits)
DATABASE_URL=postgres://postgres:postgres@localhost:5434/lunatech_betting

# HTTP
BIND_ADDR=127.0.0.1:3000
BASE_URL=http://localhost:3000

# Session cookie signing key (64+ random bytes, base64).
# Si DEV_MODE=true et que cette variable est absente, une clé aléatoire
# est générée au démarrage (les sessions sautent à chaque redémarrage).
COOKIE_KEY=replace_me_with_64_random_bytes_base64_encoded

# SMTP for magic links (Mailpit/Mailhog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=false
MAIL_FROM=lunatech-betting@lunatech.com

# football-data.org API
FOOTBALL_DATA_API_KEY=your_api_key_here
FOOTBALL_DATA_COMPETITION=WC

# Restrict signups to this email domain
ALLOWED_EMAIL_DOMAIN=lunatech.com

# Liste des emails admin (séparés par virgule, espaces ignorés, casse ignorée).
# Les utilisateurs avec ces emails sont automatiquement promus admin à chaque
# connexion. Un email retiré de la liste perd l'admin à sa prochaine connexion.
# Exemple: ADMIN_EMAILS=nicolas.leroux@lunatech.com,alice.dupont@lunatech.com
ADMIN_EMAILS=nicolas.leroux@lunatech.com

# Date limite pour s'inscrire au pot (RFC3339). Par défaut: fin de la phase
# de groupes WC2026 (2026-06-27 23:59 UTC).
STAKE_DEADLINE=2026-06-27T23:59:00Z

# Notifications avant chaque match
# Slack: incoming webhook (laisser vide pour désactiver)
SLACK_WEBHOOK_URL=
# Combien de minutes avant le coup d'envoi envoyer les rappels
REMINDER_LEAD_MINUTES=120

# Heure locale Amsterdam (0-23) a partir de laquelle l'email de recap des resultats part le matin
DAILY_DIGEST_HOUR=8
# Heure locale Amsterdam (0-23) a partir de laquelle l'email des matches a venir part
TODAY_MATCHES_HOUR=17

# Mode développement : active la page /dev (login en un clic),
# autorise COOKIE_KEY absent, ne plante pas si SMTP indisponible.
DEV_MODE=true

RUST_LOG=lunatech_betting=debug,tower_http=info
