# Rust build output
src-tauri/target/

# The generated iOS/Android projects (src-tauri/gen) ARE committed so the
# deep-link wiring (associated domains, app-links intent filter) and any native
# customisation survive. Only their build artifacts are ignored below.
src-tauri/gen/android/.gradle/
src-tauri/gen/android/.idea/
src-tauri/gen/android/app/build/
src-tauri/gen/android/build/
src-tauri/gen/android/local.properties
src-tauri/gen/apple/build/
src-tauri/gen/apple/Pods/
src-tauri/gen/apple/Externals/
src-tauri/gen/apple/.tauri/

# Signing material, never commit
*.keystore
*.jks
*.p8
*.p12
*.mobileprovision
