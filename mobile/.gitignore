# Rust build output
src-tauri/target/

# Tauri-generated platform projects (regenerated by `cargo tauri ios/android init`)
src-tauri/gen/

# Generated app icons (run `cargo tauri icon` to produce them locally)
src-tauri/icons/*.png
src-tauri/icons/*.icns
src-tauri/icons/*.ico

# Signing material, never commit
*.keystore
*.p8
*.p12
*.mobileprovision
