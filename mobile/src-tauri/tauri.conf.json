{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LunaBet",
  "version": "0.1.0",
  "identifier": "com.lunatech.lunabet",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LunaBet",
        "url": "https://lunabet.eu",
        "width": 420,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
